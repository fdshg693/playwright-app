TAVILY_API_KEY=replace-with-your-tavily-api-key

# Base directory for --topic output (defaults to temp/web when unset/blank).
# always resolved from repo root, so can be set to an absolute path or a path relative to the repo root.
TAVILY_OUTPUT_DIR=temp/web

# Write logs/<script>-log.json full audit logs. Default (unset) is true.
# Set to false / 0 / no / off to suppress.
TAVILY_WRITE_LOG=true

# Echo the "Wrote full log to <path>" audit-log destination line to the terminal
# (stderr), only when a log is written (TAVILY_WRITE_LOG). Default (unset) is true.
# Set to false / 0 / no / off to silence the log-path notice (the log is still written).
# Note: result/output file paths are always shown regardless of this setting.
TAVILY_SHOW_LOG_PATH=true